# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Defaults for all files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# C/C++ source files
[*.{c,cpp,cc,cxx,h,hpp,hh,hxx}]
indent_style = tab
indent_size = 4
end_of_line = crlf

# Visual Studio project files
[*.{sln,vcxproj,vcxproj.filters,vcxproj.user}]
indent_style = tab
end_of_line = crlf

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Makefiles
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
end_of_line = lf
indent_style = tab

# Batch files
[*.{bat,cmd}]
end_of_line = crlf
indent_style = tab

# GLSL shader files
[*.{vert,frag,glsl}]
indent_style = tab
indent_size = 4
end_of_line = crlf

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2
